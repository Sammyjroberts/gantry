#!/bin/sh
# commit-msg hook: enforce Conventional Commits for the Gantry monorepo.
# POSIX sh only (runs under Git's bundled sh on Windows). No node/npm deps.
# Full ruleset: .claude/skills/git/SKILL.md
#
# Blocks on: bad type/format, header > 72 chars, empty description.
# Warns (never blocks) on: a scope outside the known product/area map.
# Exempt: merge, revert, and fixup!/squash!/amend! commits.

msg_file="$1"

# First non-empty, non-comment line is the header (strip any CR from CRLF).
header=$(grep -v '^#' "$msg_file" | sed -n '/./{p;q;}' | tr -d '\r')

types='feat|fix|docs|refactor|perf|test|build|ci|chore'
known_scopes='edge backend web sdk proto libs-go libs-ts deploy bazel docs skills'

# --- Exemptions: never block these -----------------------------------------
case "$header" in
  'Merge '*|'Revert '*|'fixup!'*|'squash!'*|'amend!'*|'revert:'*|'revert('*)
    exit 0 ;;
esac

fail() {
  echo "commit-msg: $1"
  echo
  echo "  header: $header"
  echo
  echo "Expected Conventional Commit:  <type>(<scope>)!: <description>"
  echo "  types: $types"
  echo "  valid examples:"
  echo "    feat(sdk): add spool sink with drop-oldest ring buffer"
  echo "    fix(edge): flush stream-open response before first frame"
  echo
  echo "See .claude/skills/git/SKILL.md"
  exit 1
}

# --- Format check ----------------------------------------------------------
if ! printf '%s\n' "$header" | grep -Eq "^(${types})(\([a-z0-9-]+\))?!?: .+"; then
  fail "header is not a valid Conventional Commit"
fi

# --- Non-empty description (after the colon, must have a non-space char) ----
desc=$(printf '%s\n' "$header" | sed -E "s/^(${types})(\([a-z0-9-]+\))?!?: //")
if [ -z "$(printf '%s' "$desc" | tr -d ' ')" ]; then
  fail "description after the colon is empty"
fi

# --- Length check (hard limit, no warning tier) ----------------------------
len=$(printf '%s' "$header" | wc -c | tr -d ' ')
if [ "$len" -gt 72 ]; then
  fail "header is ${len} chars (max 72)"
fi

# --- Scope check (WARN only; new scopes must be deliberate, not blocked) ----
scope=$(printf '%s\n' "$header" | sed -n -E "s/^(${types})\(([a-z0-9-]+)\).*/\2/p")
if [ -n "$scope" ]; then
  found=0
  for s in $known_scopes; do
    [ "$s" = "$scope" ] && found=1 && break
  done
  if [ "$found" -eq 0 ]; then
    echo "commit-msg: warning: scope '$scope' is not in the known scope map."
    echo "  known: $known_scopes"
    echo "  If this is a new area, add it to .claude/skills/git/SKILL.md first."
  fi
fi

exit 0
