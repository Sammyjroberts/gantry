# Go
*.exe
*.test
*.out

# Rust
target/

# Node
node_modules/
dist/
*.tsbuildinfo
# ...but the Bench binary embeds a committed placeholder UI; the real web build
# overwrites this dist/ at build time (see justfile: embed-ui). Only the
# placeholder index.html is tracked; real build assets stay ignored.
!apps/bench/internal/ui/dist/
apps/bench/internal/ui/dist/*
!apps/bench/internal/ui/dist/index.html

# Bazel
bazel-*
MODULE.bazel.lock

# Buf/codegen — gen/ is committed (single source of truth is proto/, but we commit
# generated code so plain `go build` works without buf installed)

# Editors / OS
.idea/
.vscode/
*.swp
.DS_Store

# Local data
*.db
*.sqlite
data/
.env
.env.local

# Local-only working dirs (benchmarks/scratch/design docs live in a separate private repo)
/test_eav/
/lab/
/docs/
