# Go
*.exe
*.test
*.out

# Rust
target/

# Node
node_modules/
dist/
*.tsbuildinfo
# ...but the Edge binary embeds a committed placeholder UI; the real web build
# overwrites this dist/ at build time (see justfile: embed-ui). Only the
# placeholder index.html is tracked; real build assets stay ignored.
!apps/edge/internal/ui/dist/
apps/edge/internal/ui/dist/*
!apps/edge/internal/ui/dist/index.html

# Bazel
bazel-*
MODULE.bazel.lock

# Buf/codegen — gen/ is committed (single source of truth is proto/, but we commit
# generated code so plain `go build` works without buf installed)

# Editors / OS
.idea/
.vscode/
*.swp
.DS_Store

# Local data
*.db
*.sqlite
data/
.env
.env.local
