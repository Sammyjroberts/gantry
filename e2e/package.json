{
  "name": "@gantry/e2e",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser end-to-end suite (Playwright + real Edge binary). Self-contained; not part of the pnpm workspace.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "install:browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
